from dataclasses import dataclass
from re import Pattern

@dataclass
class MutationErrorConfig:
    success_keywords: set[str] = ...
    error_prefixes: set[str] = ...
    error_keywords: set[str] = ...
    error_pattern: Pattern[str] | None = ...
    always_return_as_data: bool = ...
    def is_error_status(self, status: str) -> bool: ...
    def get_error_code(self, status: str) -> int: ...

# Pre-configured error configurations
DEFAULT_ERROR_CONFIG: MutationErrorConfig
STRICT_STATUS_CONFIG: MutationErrorConfig

# Deprecated factory: returns a config with always_return_as_data=True.
def ALWAYS_DATA_CONFIG() -> MutationErrorConfig: ...

__all__ = [
    "ALWAYS_DATA_CONFIG",
    "DEFAULT_ERROR_CONFIG",
    "STRICT_STATUS_CONFIG",
    "MutationErrorConfig",
]
